---
import Wordmark from "./Wordmark.astro";
const phone = "60179498579";
const phoneDisplay = "+60 17-949 8579";
const ig = "ninedegrees_kl";
const email = "ninedegreeskl@gmail.com";
const year = new Date().getFullYear();
---

<footer class="foot" aria-label="Site footer">
  <div class="foot__inner gutter">
    <div class="foot__brand">
      <Wordmark size="md" />
      <p class="foot__manifesto">
        Nightlife marketing in Kuala Lumpur. Currently with
        <span class="foot__hl">404 Club Not Found</span> and
        <span class="foot__hl">Nono Club</span>, both at TREC.
        Est. 2025.
      </p>
    </div>

    <div class="foot__col">
      <h3 class="foot__heading t-mono-caps">Talk</h3>
      <ul class="foot__list">
        <li>
          <a href={`https://wa.me/${phone}`} target="_blank" rel="noopener">
            <span class="foot__action">WhatsApp</span>
            <span class="foot__detail">{phoneDisplay}</span>
          </a>
        </li>
        <li>
          <a href={`https://instagram.com/${ig}`} target="_blank" rel="noopener">
            <span class="foot__action">Instagram</span>
            <span class="foot__detail">@{ig}</span>
          </a>
        </li>
        <li>
          <a href={`mailto:${email}`}>
            <span class="foot__action">Email</span>
            <span class="foot__detail">{email}</span>
          </a>
        </li>
      </ul>
    </div>

    <div class="foot__col">
      <h3 class="foot__heading t-mono-caps">Page</h3>
      <ul class="foot__list foot__list--links">
        <li><a href="#top">Top</a></li>
        <li><a href="#venues">Venues</a></li>
        <li><a href="#nights">Recent nights</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </div>
  </div>

  <div class="foot__base gutter">
    <span class="t-meta">© {year} 9 Degrees Sdn Bhd · Kuala Lumpur, Malaysia</span>
    <span class="t-meta foot__base-right">
      <span aria-hidden="true">●</span> Currently open
    </span>
  </div>
</footer>

<style>
  .foot {
    background: var(--c-room-flush);
    color: var(--c-strobe);
    border-top: 1px solid var(--c-cyan);
    padding-top: var(--section-y);
  }

  .foot__inner {
    max-width: 1500px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    padding-bottom: var(--section-y-tight);
  }

  .foot__brand {
    display: grid;
    gap: 1.5rem;
    align-content: start;
  }
  .foot__hl {
    color: var(--c-strobe);
    font-weight: var(--fw-medium);
  }

  .foot__heading {
    color: var(--c-cyan);
    margin-bottom: 1.25rem;
  }

  .foot__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.95rem;
  }

  .foot__list a {
    display: grid;
    gap: 0.15rem;
    transition: color var(--d-fast) var(--ease-out-quart);
  }
  .foot__list a:hover { color: var(--c-cyan); }

  .foot__action {
    font-weight: var(--fw-medium);
    font-size: 1rem;
  }
  .foot__detail {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--c-smoke);
    letter-spacing: var(--ls-mono);
  }

  .foot__list--links {
    gap: 0.5rem;
  }
  .foot__list--links a {
    color: var(--c-smoke);
    font-size: 0.95rem;
    transition: color var(--d-fast) var(--ease-out-quart),
                padding-left var(--d-fast) var(--ease-out-quart);
  }
  .foot__list--links a:hover {
    color: var(--c-cyan);
    padding-left: 0.4rem;
  }

  .foot__manifesto {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--c-smoke);
    max-width: 42ch;
    margin: 0;
  }

  .foot__base {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-block: 1.5rem;
    border-top: var(--rule-hairline);
    color: var(--c-smoke-dim);
  }
  .foot__base-right {
    color: var(--c-cyan);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .foot__base-right [aria-hidden="true"] {
    font-size: 0.5em;
    transform: translateY(-1px);
  }

  @media (max-width: 980px) {
    .foot__inner {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    .foot__brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 520px) {
    .foot__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
