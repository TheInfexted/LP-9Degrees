---
/**
 * NINE° wordmark.
 *
 * Uses the brand's full stacked lockup (`/img/logo-full-trim.png` —
 * mark + NINE° type, generated by scripts/process-logo.mjs from
 * the source `logo-full.png`). When that asset is missing, falls back
 * to the cyan-only trimmed mark + a typeset NINE° wordmark.
 *
 * Sizing is em-relative so the same component works in nav, hero, and footer.
 */
import fs from "node:fs";
import path from "node:path";

const FULL_FS = path.resolve("./public/img/logo-full-trim.png");
const hasFull = fs.existsSync(FULL_FS);

interface Props {
  size?: "sm" | "md" | "lg";
  ariaLabel?: string;
  class?: string;
}
const {
  size = "md",
  ariaLabel = "NINE°, home",
  class: className = "",
} = Astro.props;
---

{hasFull ? (
  <a class={`wordmark wordmark--full wordmark--${size} ${className}`} href="#top" aria-label={ariaLabel}>
    <img
      class="wordmark__full"
      src="/img/logo-full-trim.png"
      alt="NINE°"
      width="648"
      height="870"
      decoding="async"
    />
  </a>
) : (
  <a class={`wordmark wordmark--inline wordmark--${size} ${className}`} href="#top" aria-label={ariaLabel}>
    <img
      class="wordmark__mark"
      src="/img/logo-trim.png"
      alt=""
      width="949"
      height="764"
      decoding="async"
      aria-hidden="true"
    />
    <span class="wordmark__text">
      NINE<span class="wordmark__deg" aria-hidden="true">°</span>
    </span>
  </a>
)}

<style>
  .wordmark {
    display: inline-flex;
    line-height: 1;
    text-decoration: none;
    transition: filter var(--d-fast) var(--ease-out-quart);
  }
  .wordmark:hover {
    filter: drop-shadow(0 0 16px var(--c-cyan-bloom));
  }
  .wordmark:focus-visible { outline-offset: 6px; }

  /* ─── Full stacked lockup variant (mark on top + NINE° below) ─── */
  .wordmark--full {
    align-items: flex-start;
  }
  .wordmark__full {
    display: block;
    width: auto;
    /* Aspect ratio of logo-full-trim.png is 648:870 ≈ 0.745
       We size by height; width follows. */
  }
  .wordmark--full.wordmark--sm .wordmark__full { height: clamp(3.5rem, 5.5vw, 5rem); }   /* nav */
  .wordmark--full.wordmark--md .wordmark__full { height: clamp(4.5rem, 7vw, 6.5rem); }   /* footer */
  .wordmark--full.wordmark--lg .wordmark__full { height: clamp(7rem, 12vw, 11rem); }     /* hero / large */

  /* ─── Inline fallback variant (icon + typeset NINE° text) ─── */
  .wordmark--inline {
    align-items: center;
    gap: 0.55em;
  }
  .wordmark--inline.wordmark--sm { font-size: 1.125rem; }
  .wordmark--inline.wordmark--md { font-size: 1.5rem; }
  .wordmark--inline.wordmark--lg { font-size: 2.5rem; }

  .wordmark__mark {
    height: 1.05em;
    width: auto;
    display: block;
  }

  .wordmark__text {
    font-weight: var(--fw-black);
    letter-spacing: -0.02em;
    color: var(--c-strobe);
    font-feature-settings: "ss01";
  }

  .wordmark__deg {
    color: var(--c-cyan);
    margin-left: 0.06em;
    font-feature-settings: "ss01";
  }
</style>
